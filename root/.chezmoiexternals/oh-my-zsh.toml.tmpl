{{ if ne .osId "windows" }}

##########################################

[".oh-my-zsh"]
exact = true
refreshPeriod = "168h"
stripComponents = 1
type = "archive"
url = "https://github.com/ohmyzsh/ohmyzsh/archive/master.tar.gz"
include = ["*/lib/**", "*/plugins/**", "*/themes/**", "*/oh-my-zsh.sh"]

[".oh-my-zsh/custom/plugins/zsh-autosuggestions"]
exact = true
refreshPeriod = "168h"
stripComponents = 1
type = "archive"
url = "https://github.com/zsh-users/zsh-autosuggestions/archive/master.tar.gz"
include = ["*/*.zsh", "*/VERSION"]

[".oh-my-zsh/custom/plugins/zsh-history-substring-search"]
exact = true
refreshPeriod = "168h"
stripComponents = 1
type = "archive"
url = "https://github.com/zsh-users/zsh-history-substring-search/archive/master.tar.gz"

[".oh-my-zsh/custom/plugins/zsh-syntax-highlighting"]
exact = true
refreshPeriod = "168h"
stripComponents = 1
type = "archive"
url = "https://github.com/zsh-users/zsh-syntax-highlighting/archive/master.tar.gz"
include = ["*/zsh-syntax-highlighting.zsh", "*/highlighters/**", "*/.version", "*/.revision-hash"]

[".oh-my-zsh/custom/themes/powerlevel10k"]
exact = true
refreshPeriod = "168h"
stripComponents = 1
type = "archive"
url = "https://github.com/romkatv/powerlevel10k/archive/master.tar.gz"
include = ["*/*.zsh", "*/*.zsh-theme", "*/config/*", "*/gitstatus/*"]

##########################################

{{ end }}
